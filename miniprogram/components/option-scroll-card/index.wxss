.osc-wrap {
  width: 100%;
  box-sizing: border-box;
}

/* 横向滚动: white-space:nowrap + inline-flex 消基线间隙 + 定宽让首屏刚好 2 个 */
.osc-list {
  white-space: nowrap;
  width: 100%;
}

/* 每组 = 上图文 + 下选项卡, 整组横滑; 组本身无边框, 只提供宽度和间距 */
.osc-group {
  display: inline-flex;
  flex-direction: column;
  vertical-align: top;                       /* 与 inline-flex 一起消基线间隙 */
  width: calc((100% - 16rpx) / 2);           /* 精确 2 列, 间距 16rpx */
  margin-right: 16rpx;
  box-sizing: border-box;
}

.osc-group:last-child { margin-right: 0; }

/* ================ default 变体 (materials 页): 图文 + 选项卡 两块分离 ================ */

.osc-desc {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 18rpx;
  margin-bottom: 12rpx;
  background: #f9fafb;
  border-radius: 12rpx;
}

.osc-desc-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  background: #e5e7eb;
  flex-shrink: 0;
}

.osc-desc-img--placeholder { /* 灰底占位 */ }

.osc-desc-text {
  flex: 1;
  font-size: 22rpx;
  color: #4b5563;
  line-height: 1.5;
  white-space: normal;
  word-break: break-all;
  display: -webkit-box;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.osc-item {
  padding: 22rpx 18rpx;
  box-sizing: border-box;
  background: #fff;
  border: 2rpx solid #e5e7eb;
  border-radius: 14rpx;
}

.osc-item.active {
  border-color: #1f2937;
  background: #fef9c3;
}

.osc-item-name {
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 500;
  white-space: normal;
  word-break: break-all;
}

.osc-item-desc {
  font-size: 22rpx;
  color: #6b7280;
  margin-top: 4rpx;
  white-space: normal;
  word-break: break-all;
}

/* ================ card 变体 (空间设置转角): 竖长卡牌 · iOS 大圆角 ================ */

/* 定宽 300rpx, 高 400rpx (300 * 4/3) → 精确 3:4;
   首屏默认可见 2 张 (section 内宽 ~694rpx, 2 张 + gap = 616rpx, 剩 78rpx 露 3 张的头) */
.osc-group--card {
  width: 300rpx;
  margin-right: 16rpx;
}
.osc-group--card:last-child { margin-right: 0; }

.osc-card {
  display: flex;
  flex-direction: column;
  height: 400rpx;            /* 3:4 (300 * 4/3) */
  overflow: hidden;
  background: #fff;
  border: 2rpx solid #e5e7eb;
  border-radius: 32rpx;      /* iOS 感的大圆角 */
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: box-shadow 0.15s ease;
}

.osc-card.active {
  border-color: #1f2937;
  background: #fef9c3;
  box-shadow: 0 6rpx 20rpx rgba(31, 41, 55, 0.15);
}

/* 上部: 左图 + 右文 (卡宽 300rpx 可以承载左右分隔布局), flex:1 撑满除底部选项名以外 */
.osc-card-panel {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 12rpx;
  padding: 18rpx 16rpx;
}

.osc-card-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 14rpx;
  background: #e5e7eb;
  flex-shrink: 0;
}

.osc-card-img--placeholder { /* 灰底占位 */ }

.osc-card-text {
  flex: 1;
  font-size: 22rpx;
  color: #4b5563;
  line-height: 1.5;
  white-space: normal;
  word-break: break-all;
  display: -webkit-box;
  -webkit-line-clamp: 6;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 下部: 居中选项名 (+ 可选副标题), 细分隔线与上部隔开 */
.osc-card-footer {
  padding: 14rpx 16rpx 18rpx;
  border-top: 2rpx solid #f3f4f6;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.osc-card-name {
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  white-space: normal;
  word-break: break-all;
}

.osc-card-desc {
  text-align: center;
  font-size: 22rpx;
  color: #6b7280;
  white-space: normal;
  word-break: break-all;
}

/* ================ 自定义横向滑动条 ================ */

/* 参照 cabinet/pages/design/index.wxss 的 .scroll-indicator。 */
.osc-indicator {
  position: relative;
  height: 16rpx;
  background: #e5e7eb;
  border-radius: 8rpx;
  margin: 14rpx 8rpx 0 8rpx;
}

.osc-indicator-thumb {
  position: absolute;
  top: 0;
  bottom: 0;
  background: #1f2937;
  border-radius: 8rpx;
  pointer-events: none;
}
