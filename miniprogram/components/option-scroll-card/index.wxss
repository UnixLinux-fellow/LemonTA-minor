.osc-wrap {
  width: 100%;
  box-sizing: border-box;
}

/* 横向滚动: white-space:nowrap + inline-flex 消基线间隙 + 定宽让首屏刚好 2 个 */
.osc-list {
  white-space: nowrap;
  width: 100%;
}

/* 每组 = 上图文 + 下选项卡, 整组横滑; 组本身无边框, 只提供宽度和间距 */
.osc-group {
  display: inline-flex;
  flex-direction: column;
  vertical-align: top;                       /* 与 inline-flex 一起消基线间隙 */
  width: calc((100% - 16rpx) / 2);           /* 精确 2 列, 间距 16rpx */
  margin-right: 16rpx;
  box-sizing: border-box;
}

.osc-group:last-child { margin-right: 0; }

/* 上方图文说明区: 独立容器, 浅灰底, 无边框; 与下方选项卡视觉分离 */
.osc-desc {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 18rpx;
  margin-bottom: 12rpx;
  background: #f9fafb;
  border-radius: 12rpx;
}

.osc-desc-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  background: #e5e7eb;
  flex-shrink: 0;
}

.osc-desc-img--placeholder {
  /* 灰底 + 无 src, 已足够表达"加载中/无图" */
}

.osc-desc-text {
  flex: 1;
  font-size: 22rpx;
  color: #4b5563;
  line-height: 1.5;
  white-space: normal;
  word-break: break-all;
  /* 4 行截断, 避免顶部说明块把整组撑得过高 */
  display: -webkit-box;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 下方选项卡: 保持之前样式 (白底 + 灰边 + 圆角 + 选中变黄) */
.osc-item {
  padding: 22rpx 18rpx;
  box-sizing: border-box;
  background: #fff;
  border: 2rpx solid #e5e7eb;
  border-radius: 14rpx;
}

.osc-item.active {
  border-color: #1f2937;
  background: #fef9c3;
}

.osc-item-name {
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 500;
  white-space: normal;         /* 单独放开, 避免 osc-list 的 nowrap 影响卡片内 */
  word-break: break-all;
}

.osc-item-desc {
  font-size: 22rpx;
  color: #6b7280;
  margin-top: 4rpx;
  white-space: normal;
  word-break: break-all;
}

/* 自定义横向滑动条: 参照 cabinet/pages/design/index.wxss 的 .scroll-indicator。
   scroll-view 原生 scrollbar 在小程序里各机型样式不一致, 走自定义 indicator。
   通过 <scroll-view bindscroll> 反馈 scrollLeft, 组件里同步算 thumb 位置。 */
.osc-indicator {
  position: relative;
  height: 16rpx;
  background: #e5e7eb;
  border-radius: 8rpx;
  margin: 14rpx 8rpx 0 8rpx;
}

.osc-indicator-thumb {
  position: absolute;
  top: 0;
  bottom: 0;
  background: #1f2937;
  border-radius: 8rpx;
  pointer-events: none;
}
