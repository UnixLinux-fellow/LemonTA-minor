<view class="osc-wrap">
  <scroll-view class="osc-list" scroll-x="{{true}}" show-scrollbar="{{false}}"
               bounces="{{true}}" bindscroll="onListScroll">
    <!-- 每组 = 上方图文说明区 + 下方选项卡, 整组作为一个横滑单元 -->
    <view wx:for="{{displayOptions}}" wx:key="id"
          class="osc-group"
          data-id="{{item.id}}" bindtap="onPick">
      <!-- 上方图文说明区 (独立容器, 无边框, 浅灰底) -->
      <view class="osc-desc" wx:if="{{showDesc}}">
        <image wx:if="{{item.imagePath}}" class="osc-desc-img"
               src="{{item.imagePath}}" mode="aspectFill" />
        <view wx:else class="osc-desc-img osc-desc-img--placeholder"></view>
        <view class="osc-desc-text">{{item.descText}}</view>
      </view>
      <!-- 下方选项卡: 保持之前样式 (白底 + 灰边 + 圆角 + 选中变黄) -->
      <view class="osc-item {{selectedId === item.id ? 'active' : ''}}">
        <view class="osc-item-name">{{item.name}}</view>
        <view wx:if="{{item.desc}}" class="osc-item-desc">{{item.desc}}</view>
      </view>
    </view>
  </scroll-view>

  <!-- 自定义横向滑动条 (参照 cabinet/pages/design 的 scroll-indicator 样式);
       超过 2 个选项 (需要横滑) 时才显示 -->
  <view wx:if="{{scrollNeeded}}" class="osc-indicator">
    <view class="osc-indicator-thumb"
          style="width: {{thumbWidthPct}}%; left: {{thumbLeftPct}}%;">
    </view>
  </view>
</view>
