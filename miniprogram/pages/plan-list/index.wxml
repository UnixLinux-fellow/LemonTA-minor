<view class="page">
  <view class="hero">
    <view class="hero-title">我的设计</view>
    <view class="hero-sub">最多保存 30 个空间方案</view>
    <button class="start-btn" bindtap="onTapStart">开始新设计</button>
  </view>

  <view class="list-wrap" wx:if="{{plans.length}}">
    <view class="list-title">已保存方案 ({{plans.length}}/30)</view>
    <view class="plan-item" wx:for="{{plans}}" wx:key="id">
      <view class="plan-main" data-id="{{item.id}}" bindtap="onTapItem">
        <view class="plan-name">{{item.name}}</view>
        <view class="plan-meta">
          <text>{{item.wall.w}}cm × {{item.wall.h}}cm</text>
          <text class="dot">·</text>
          <text>{{item.cornerLabel}}</text>
          <text class="dot">·</text>
          <text>{{item.cabinetCount}} 个柜子</text>
        </view>
      </view>
      <view class="del-btn" data-id="{{item.id}}" catchtap="onAskDelete">✕</view>
    </view>
  </view>

  <view class="empty" wx:else>
    <view class="empty-text">还没有保存的设计</view>
    <view class="empty-tip">点击上方"开始新设计"开始第一个空间</view>
  </view>

  <view class="modal" wx:if="{{confirmDelete}}">
    <view class="modal-mask" bindtap="onConfirmDeleteCancel"></view>
    <view class="modal-card">
      <view class="modal-title">删除设计？</view>
      <view class="modal-body">将删除"{{confirmDelete.name}}"，无法恢复。</view>
      <view class="modal-actions">
        <view class="modal-btn" bindtap="onConfirmDeleteCancel">否</view>
        <view class="modal-btn primary" bindtap="onConfirmDeleteOk">确认删除</view>
      </view>
    </view>
  </view>

  <view class="export-btn-wrap">
    <view class="export-btn" bindtap="onTapExport">导出方案信息</view>
    <view class="export-btn export-btn-hardware" bindtap="onTapExportHardware">导出五金/尺寸</view>
  </view>

  <plan-select-modal
    visible="{{exportSelectOpen}}"
    plans="{{plans}}"
    bind:cancel="onExportSelectCancel"
    bind:confirm="onExportSelectConfirm">
  </plan-select-modal>

  <filename-input-modal
    visible="{{exportNameOpen}}"
    bind:cancel="onExportNameCancel"
    bind:confirm="onExportNameConfirm">
  </filename-input-modal>

  <filename-input-modal
    visible="{{hardwareExportNameOpen}}"
    defaultValue="五金尺寸参考.pdf"
    bind:cancel="onHardwareExportNameCancel"
    bind:confirm="onHardwareExportNameConfirm">
  </filename-input-modal>

  <canvas type="2d" id="pdf-canvas" class="pdf-canvas"></canvas>

  <cabinet-toast text="{{toast}}"></cabinet-toast>
</view>
