/* pages/profile/feedback/feedback.wxss */

.page-container { min-height: 100vh; background: #f5f5f5; }

/* 导航栏覆盖：白色背景 */
.custom-nav {
  background: #fff;
}

.nav-title {
  font-size: 32rpx;
}

.feedback-content { padding: 20rpx 30rpx; }

.feedback-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.feedback-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  display: block;
}

.feedback-input {
  width: 100%;
  height: 260rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 30rpx;
}

/* 图片上传区域 */
.upload-area {
  width: 150rpx;
  height: 150rpx;
  border: 3rpx dashed #d0d0d0;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  overflow: hidden;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.upload-icon {
  font-size: 60rpx;
  color: #ccc;
}

.upload-preview {
  width: 100%;
  height: 100%;
}

/* 按钮行 */
.feedback-btns {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 30rpx;
}

.btn-cancel {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  color: #333;
  padding: 16rpx 0;
  border-right: 1rpx solid #f0f0f0;
}

.btn-confirm {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  color: #FC9700;
  font-weight: bold;
  padding: 16rpx 0;
}
