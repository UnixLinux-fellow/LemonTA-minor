/* pages/profile/profile.wxss - iOS 风格我的页 · Apple HIG 排版 */

.page-container {
  min-height: 100vh;
  background: #f5f5f7;
  position: relative;
}

/* ===== 头部 ===== */
.profile-header {
  padding: 40rpx 36rpx 20rpx;
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.header-eyebrow {
  font-size: 22rpx;
  font-weight: 700;
  color: #FC9700;
  letter-spacing: 5rpx;
  line-height: 1;
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 80rpx;
  font-weight: 800;
  color: #1d1d1f;
  line-height: 1;
  letter-spacing: -2.4rpx;
  margin-bottom: 44rpx;
}

/* ===== 账户大卡 ===== */
.account-card {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 32rpx 32rpx;
  background: rgba(255, 255, 255, 0.82);
  backdrop-filter: saturate(180%) blur(30px);
  -webkit-backdrop-filter: saturate(180%) blur(30px);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  border-radius: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06),
              0 2rpx 8rpx rgba(0, 0, 0, 0.03);
  box-sizing: border-box;
  transition: transform 0.15s ease, opacity 0.15s ease;
}

/* 点击反馈：未登录态引导用户去登录页 */
.account-card-hover {
  opacity: 0.88;
  transform: scale(0.99);
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFB140 0%, #FC9700 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(252, 151, 0, 0.35);
  flex-shrink: 0;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-text {
  color: #ffffff;
  font-size: 52rpx;
  font-weight: 800;
  letter-spacing: -0.5rpx;
}

/* 编辑资料小按钮（账户卡右侧铅笔图标） */
.edit-profile-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(252, 151, 0, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: background 0.15s ease;
}

.edit-profile-btn-hover {
  background: rgba(252, 151, 0, 0.25);
}

.edit-profile-icon {
  font-size: 30rpx;
  color: #FC9700;
  font-weight: 600;
  line-height: 1;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.user-phone {
  font-size: 40rpx;
  font-weight: 700;
  color: #1d1d1f;
  letter-spacing: -0.5rpx;
  line-height: 1.1;
}

.user-email {
  font-size: 24rpx;
  color: #86868b;
  font-weight: 500;
  letter-spacing: 0.2rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-email-empty {
  color: #FC9700;
  font-weight: 600;
}

/* ===== 菜单区 ===== */
.profile-body {
  padding: 48rpx 36rpx 60rpx;
  position: relative;
  z-index: 1;
}

/* 分组标题 */
.group-label {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
  margin-top: 8rpx;
  padding: 0 8rpx;
}

.group-label:first-child {
  margin-top: 0;
}

.group-label-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #6e6e73;
  letter-spacing: 0.5rpx;
  text-transform: uppercase;
  flex-shrink: 0;
}

.group-label-line {
  flex: 1;
  height: 1rpx;
  background: rgba(60, 60, 67, 0.1);
}

.menu-card {
  background: rgba(255, 255, 255, 0.82);
  backdrop-filter: saturate(180%) blur(30px);
  -webkit-backdrop-filter: saturate(180%) blur(30px);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
  margin-bottom: 36rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 26rpx 28rpx;
  border-bottom: 1rpx solid rgba(60, 60, 67, 0.08);
  transition: background 0.2s ease;
  gap: 20rpx;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item-hover {
  background: rgba(120, 120, 128, 0.08);
}

.menu-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  flex-shrink: 0;
}

.menu-icon-orange {
  background: linear-gradient(135deg, rgba(252, 151, 0, 0.18) 0%, rgba(252, 151, 0, 0.08) 100%);
}

.menu-icon-blue {
  background: linear-gradient(135deg, rgba(10, 132, 255, 0.18) 0%, rgba(10, 132, 255, 0.08) 100%);
}

.menu-icon-green {
  background: linear-gradient(135deg, rgba(52, 199, 89, 0.18) 0%, rgba(52, 199, 89, 0.08) 100%);
}

.menu-icon-purple {
  background: linear-gradient(135deg, rgba(175, 82, 222, 0.18) 0%, rgba(175, 82, 222, 0.08) 100%);
}

.menu-icon-img {
  width: 38rpx;
  height: 38rpx;
}

.menu-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.menu-text {
  font-size: 32rpx;
  color: #1d1d1f;
  font-weight: 600;
  letter-spacing: -0.2rpx;
  line-height: 1.25;
}

.menu-hint {
  font-size: 22rpx;
  color: #86868b;
  font-weight: 500;
  letter-spacing: 0.2rpx;
  line-height: 1.3;
}

.menu-arrow {
  font-size: 40rpx;
  color: #c7c7cc;
  font-weight: 300;
  line-height: 1;
  flex-shrink: 0;
}

/* 版本号 */
.app-version {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #c7c7cc;
  font-weight: 500;
  letter-spacing: 1rpx;
  margin-top: 40rpx;
}

/* ===================== 编辑资料弹窗 ===================== */

.edit-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.18s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

.edit-modal {
  width: 600rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx 36rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.22);
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: modalIn 0.2s ease;
}

@keyframes modalIn {
  from { opacity: 0; transform: translateY(40rpx) scale(0.96); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}

.edit-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1d1d1f;
  letter-spacing: -0.3rpx;
}

.edit-hint {
  font-size: 24rpx;
  color: #86868b;
  margin-top: 8rpx;
  margin-bottom: 36rpx;
}

/* ----- 头像选择区 ----- */
.edit-avatar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 36rpx;
}

.edit-avatar-btn {
  width: 180rpx;
  height: 180rpx;
  padding: 0;
  border: none;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFF4E0 0%, #FFE0B2 100%);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(252, 151, 0, 0.2);
  position: relative;
}

.edit-avatar-btn::after {
  border: none;
}

.edit-avatar-btn-hover {
  opacity: 0.9;
  transform: scale(0.98);
}

.edit-avatar-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
}

.edit-avatar-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.edit-avatar-plus {
  font-size: 56rpx;
  color: #FC9700;
  font-weight: 300;
  line-height: 1;
}

.edit-avatar-tip {
  font-size: 22rpx;
  color: #FC9700;
  font-weight: 500;
}

.edit-avatar-label {
  font-size: 22rpx;
  color: #86868b;
  margin-top: 16rpx;
}

/* ----- 昵称输入 ----- */
.edit-nick-wrap {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 24rpx;
  background: #f5f5f7;
  border-radius: 16rpx;
  margin-bottom: 36rpx;
}

.edit-nick-label {
  font-size: 28rpx;
  color: #1d1d1f;
  font-weight: 600;
  flex-shrink: 0;
}

.edit-nick-input {
  flex: 1;
  font-size: 28rpx;
  color: #1d1d1f;
  background: transparent;
  min-width: 0;
}

/* ----- 底部按钮 ----- */
.edit-actions {
  width: 100%;
  display: flex;
  gap: 20rpx;
}

.edit-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0;
  margin: 0;
  border: none;
}

.edit-btn::after {
  border: none;
}

.edit-btn-cancel {
  background: #f5f5f7;
  color: #1d1d1f;
}

.edit-btn-save {
  background: #FC9700;
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(252, 151, 0, 0.35);
}
