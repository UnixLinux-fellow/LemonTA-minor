<!--pages/knowledge/detail/detail.wxml-->
<view class="page-container">
  <!-- 自定义导航栏 -->
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-bar" style="height: {{navBarHeight}}px;">
      <view class="nav-back" bindtap="goBack">
        <text class="back-arrow">‹</text>
      </view>
      <text class="nav-title">{{title}}</text>
    </view>
  </view>
  
  <view class="detail-content" style="padding-top: {{statusBarHeight + navBarHeight + 10}}px;">
    <view class="detail-card">
      <text class="detail-title">{{title}}</text>
      <view class="detail-body">
        <text wx:if="{{type === 'article'}}">{{articleContent}}</text>
        <view wx:if="{{type === 'download'}}" class="download-section">
          <text class="download-desc">点击下方按钮下载相关资料文件</text>
          <button class="btn-download" bindtap="onDownload">下载文件</button>
        </view>
      </view>
    </view>
  </view>
</view>
