/* pages/knowledge/detail/detail.wxss */

.page-container {
  min-height: 100vh;
  background: #f8f8f8;
}

/* 导航栏覆盖：白色背景 */
.custom-nav {
  background: #fff;
}

.nav-title {
  font-size: 32rpx;
  max-width: 450rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-content {
  padding: 20rpx 30rpx;
}

.detail-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
}

.detail-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #FC9700;
  margin-bottom: 30rpx;
  display: block;
}

.detail-body {
  font-size: 28rpx;
  color: #555;
  line-height: 2;
}

.download-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.download-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
}

.btn-download {
  background: #FC9700;
  color: #fff;
  border-radius: 50rpx;
  padding: 20rpx 80rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
}
