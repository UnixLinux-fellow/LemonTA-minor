<!--pages/knowledge/knowledge.wxml-->
<wxs src="../../utils/assets.wxs" module="assets" />
<view class="page-container">
  <bg-image name="T2" bg-class="bg-image bg-image-medium" />
  
  <!-- 自定义导航栏 -->
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-bar" style="height: {{navBarHeight}}px;">
      <text class="nav-title">知识库</text>
    </view>
  </view>
  
  <view class="knowledge-content" style="padding-top: {{statusBarHeight + navBarHeight + 40}}px;">

    <!-- 页面标题 -->
    <view class="knowledge-header">
      <text class="header-eyebrow">KNOWLEDGE BASE</text>
      <text class="header-title">LemonTA</text>
      <text class="header-title header-title-accent">知识库</text>
      <text class="header-subtitle">一键解决全流程问题 · 从预算到验收</text>
    </view>

    <!-- 分组标题 -->
    <view class="group-label">
      <text class="group-label-text">常用工具</text>
      <view class="group-label-line"></view>
    </view>

    <!-- 工具列表 -->
    <view class="article-list">
      <view class="article-item" 
            wx:for="{{knowledgeList}}" 
            wx:key="id"
            hover-class="article-item-hover"
            bindtap="openArticle" 
            data-id="{{item.id}}"
            data-title="{{item.title}}"
            data-type="{{item.type}}"
            data-imageurl="{{item.imageUrl || ''}}">
        
        <view class="article-icon">
          <text wx:if="{{item.type === 'budget'}}">🍋</text>
          <text wx:if="{{item.type === 'needs'}}">📋</text>
          <text wx:if="{{item.type === 'inspect'}}">✅</text>
          <text wx:if="{{item.type === 'image'}}">🗺️</text>
          <text wx:if="{{item.type === 'move'}}">🚛</text>
          <text wx:if="{{item.type === 'checklist'}}">🏠</text>
        </view>

        <view class="article-info">
          <text class="article-title">{{item.title}}</text>
          <text class="article-subtitle" wx:if="{{item.subtitle}}">{{item.subtitle}}</text>
        </view>

        <text class="article-arrow">›</text>
      </view>
    </view>
  </view>
</view>
