/* pages/knowledge/knowledge.wxss - iOS 风格知识库 · Apple HIG 排版 */

.knowledge-content {
  position: relative;
  z-index: 1;
  padding: 20rpx 32rpx 220rpx;
}

/* ===== 页面标题 ===== */
.knowledge-header {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-bottom: 56rpx;
  padding: 0 8rpx;
}

.header-eyebrow {
  font-size: 22rpx;
  font-weight: 700;
  color: #FC9700;
  letter-spacing: 5rpx;
  line-height: 1;
  margin-bottom: 28rpx;
}

.header-title {
  font-size: 80rpx;
  font-weight: 800;
  color: #1d1d1f;
  line-height: 1;
  letter-spacing: -2.4rpx;
}

.header-title-accent {
  background: linear-gradient(135deg, #FFB140 0%, #FC9700 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-top: 6rpx;
}

.header-subtitle {
  font-size: 28rpx;
  font-weight: 500;
  color: #6e6e73;
  letter-spacing: 0.3rpx;
  margin-top: 28rpx;
}

/* ===== 分组标题 ===== */
.group-label {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.group-label-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #1d1d1f;
  letter-spacing: -0.2rpx;
  flex-shrink: 0;
}

.group-label-line {
  flex: 1;
  height: 1rpx;
  background: rgba(60, 60, 67, 0.12);
}

/* ===== 文章列表 ===== */
.article-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.article-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: rgba(255, 255, 255, 0.82);
  backdrop-filter: saturate(180%) blur(30px);
  -webkit-backdrop-filter: saturate(180%) blur(30px);
  border-radius: 28rpx;
  padding: 28rpx 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.04),
              0 1rpx 4rpx rgba(0, 0, 0, 0.03);
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.article-item-hover {
  transform: scale(0.98);
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.article-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, rgba(252, 151, 0, 0.15) 0%, rgba(252, 151, 0, 0.05) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.article-icon text {
  font-size: 44rpx;
  line-height: 1;
}

.article-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.article-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1d1d1f;
  letter-spacing: -0.3rpx;
  line-height: 1.25;
}

.article-subtitle {
  font-size: 24rpx;
  font-weight: 500;
  color: #86868b;
  letter-spacing: 0.2rpx;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.article-arrow {
  font-size: 40rpx;
  color: #c7c7cc;
  font-weight: 300;
  line-height: 1;
  flex-shrink: 0;
}
