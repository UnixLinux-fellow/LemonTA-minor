<!--pages/knowledge/needs/needs.wxml-->
<wxs src="../../../utils/assets.wxs" module="assets" />
<view class="page-container">
  <image class="bg-image" src="{{assets.bg('T2')}}" mode="aspectFill" lazy-load />

  <!-- 自定义导航栏 -->
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-bar" style="height: {{navBarHeight}}px;">
      <view class="nav-back" bindtap="goBack">
        <text class="back-arrow">‹</text>
      </view>
      <text class="nav-title">柠檬塔需求匹配表</text>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <view class="form-content" style="padding-top: {{statusBarHeight + navBarHeight + 10}}px;">
    <!-- 顶部说明 -->
    <view class="intro-card">
      <view class="intro-icon">🍋</view>
      <text class="intro-title">柠檬塔 设计需求匹配表</text>
      <text class="intro-desc">明确自己的需求，且确认自己的需求，是开始装修的第一步。通过填写这个需求表格，明确需求，可以截图发给设计师或者供应商，减少和设计师的沟通成本。</text>
    </view>

    <!-- 保存状态提示 -->
    <view class="save-status" wx:if="{{saved}}">
      <text class="save-dot">●</text>
      <text class="save-text">已自动保存，再次打开无需重新填写</text>
    </view>

    <!-- 各STEP模块 -->
    <block wx:for="{{steps}}" wx:key="key" wx:for-item="step">
      <view class="step-section">
        <view class="step-header">
          <text class="step-title">{{step.title}}</text>
        </view>

        <view class="step-body">
          <block wx:for="{{step.questions}}" wx:key="id" wx:for-item="q">
            <!-- 条件显示控制 -->
            <view class="question-item" wx:if="{{q.visible !== false}}">
              <text class="q-label">{{q.label}}</text>

              <!-- 选项类型 -->
              <view class="q-options" wx:if="{{q.type === 'select'}}">
                <view class="option-btn {{formData[q.id] === item ? 'option-active' : ''}}"
                      wx:for="{{q.options}}" wx:key="*this" wx:for-item="item"
                      bindtap="onSelectOption"
                      data-qid="{{q.id}}" data-option="{{item}}">
                  <text>{{item}}</text>
                </view>
              </view>

              <!-- 单行输入 -->
              <input wx:if="{{q.type === 'input'}}"
                     class="q-input"
                     value="{{formData[q.id]}}"
                     placeholder="{{q.placeholder}}"
                     bindinput="onInputChange"
                     data-qid="{{q.id}}" />

              <!-- 多行文本 -->
              <textarea wx:if="{{q.type === 'textarea'}}"
                        class="q-textarea"
                        value="{{formData[q.id]}}"
                        placeholder="{{q.placeholder}}"
                        bindinput="onInputChange"
                        data-qid="{{q.id}}"
                        auto-height
                        maxlength="-1" />

              <!-- 备注输入框（hasRemark为true时显示） -->
              <view class="q-remark" wx:if="{{q.hasRemark || q.remarkPlaceholder}}">
                <input class="remark-input"
                       value="{{formData[q.id + '_remark']}}"
                       placeholder="{{q.remarkPlaceholder || '备注'}}"
                       bindinput="onRemarkChange"
                       data-qid="{{q.id}}" />
              </view>
            </view>
          </block>
        </view>
      </view>
    </block>

    <!-- 底部操作栏 -->
    <view class="bottom-actions">
      <view class="btn-save" bindtap="onSave">
        <text>💾 保存需求表</text>
      </view>
      <view class="btn-reset" bindtap="onReset">
        <text>🔄 重置表单</text>
      </view>
      <view class="tip-text">
        <text>💡 提示：可以截长图发给设计师或供应商</text>
      </view>
    </view>
  </view>
</view>
