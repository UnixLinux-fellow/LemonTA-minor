/* pages/knowledge/move/move.wxss */

.page-container {
  min-height: 100vh;
  position: relative;
}

/* 导航栏覆盖 */
.custom-nav {
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(20px);
}

.nav-bar {
  justify-content: space-between;
  padding: 0 24rpx;
}

.nav-back {
  position: static;
  width: 72rpx;
  height: 72rpx;
}

.nav-back-icon {
  font-size: 40rpx;
  font-weight: bold;
}

.nav-title {
  font-size: 32rpx;
  color: #1a1a1a;
}

.nav-placeholder {
  width: 72rpx;
}

/* 页面内容 */
.page-content {
  position: relative;
  z-index: 1;
  padding: 0 32rpx 120rpx;
}

/* ========== 步骤选择页 ========== */
.step-header {
  text-align: center;
  padding: 40rpx 0 48rpx;
}

.step-header-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.step-header-desc {
  display: block;
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
}

.step-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.step-card {
  background: rgba(255,255,255,0.95);
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  border: 2rpx solid rgba(252,151,0,0.1);
}

.step-card:active {
  transform: scale(0.98);
  background: rgba(252,151,0,0.06);
}

.step-card-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.step-card-icon {
  font-size: 48rpx;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(252,151,0,0.08);
  border-radius: 18rpx;
}

.step-card-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.step-card-label {
  font-size: 22rpx;
  color: #FC9700;
  font-weight: 600;
}

.step-card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.step-card-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.step-progress {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}

.step-progress-text {
  font-size: 22rpx;
  color: #999;
}

.step-progress-bar {
  width: 80rpx;
  height: 6rpx;
  background: #eee;
  border-radius: 3rpx;
  overflow: hidden;
}

.step-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FC9700, #FFB84D);
  border-radius: 3rpx;
  transition: width 0.3s;
}

.step-card-arrow {
  font-size: 36rpx;
  color: #ccc;
  font-weight: bold;
}

/* ========== 验收清单详情页 ========== */
.detail-header {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.95);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin: 20rpx 0 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.detail-icon {
  font-size: 56rpx;
  margin-right: 20rpx;
}

.detail-header-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.detail-header-step {
  font-size: 22rpx;
  color: #FC9700;
  font-weight: 600;
}

.detail-header-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.detail-header-progress {
  display: flex;
  align-items: baseline;
}

.detail-progress-num {
  font-size: 44rpx;
  font-weight: bold;
  color: #FC9700;
}

.detail-progress-total {
  font-size: 28rpx;
  color: #999;
}

/* 验收项列表 */
.check-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.check-item {
  background: rgba(255,255,255,0.95);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.25s;
}

.check-item:active {
  transform: scale(0.98);
}

.check-item-done {
  background: rgba(252,151,0,0.06);
  border-color: rgba(252,151,0,0.2);
}

.check-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding-top: 4rpx;
}

.check-box {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  border: 3rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
}

.check-box text {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

.check-box-checked {
  background: linear-gradient(135deg, #FC9700, #FFB84D);
  border-color: #FC9700;
}

.check-num {
  font-size: 24rpx;
  color: #ccc;
  font-weight: bold;
  min-width: 36rpx;
  text-align: center;
}

.check-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.check-desc {
  font-size: 26rpx;
  color: #333;
  line-height: 1.7;
  word-break: break-all;
  white-space: pre-wrap;
}

.check-desc-done {
  color: #999;
  text-decoration: line-through;
}

/* 备注区域 */
.notes-section {
  background: rgba(255,255,255,0.95);
  border-radius: 20rpx;
  padding: 28rpx 28rpx;
  margin-top: 28rpx;
  border-left: 6rpx solid #FC9700;
}

.notes-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.notes-icon {
  font-size: 32rpx;
}

.notes-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.notes-content {
  font-size: 24rpx;
  color: #666;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 合同提示 */
.contract-section {
  background: rgba(252,151,0,0.08);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-top: 20rpx;
}

.contract-text {
  font-size: 24rpx;
  color: #FC9700;
  font-weight: 600;
  line-height: 1.6;
}

/* 底部操作 */
.detail-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
  padding: 0 20rpx;
}

.action-reset {
  flex: 1;
  background: #f5f5f5;
  border-radius: 50rpx;
  padding: 24rpx 0;
  text-align: center;
}

.action-reset text {
  font-size: 28rpx;
  color: #999;
}

.action-back {
  flex: 1;
  background: linear-gradient(135deg, #FC9700, #FFB84D);
  border-radius: 50rpx;
  padding: 24rpx 0;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(252,151,0,0.3);
}

.action-back text {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

.bottom-space {
  height: 60rpx;
}
