<wxs src="../../utils/assets.wxs" module="assets" />
<view class="page">
  <bg-image name="T3" bg-class="bg-image bg-image-light" />

  <view class="section">
    <view class="label">空间照片</view>
    <view class="photo-zone" bindtap="onChoosePhoto">
      <image wx:if="{{photoPath}}" src="{{photoPath}}" mode="aspectFill"></image>
      <view class="photo-plus" wx:else>+</view>
    </view>
  </view>

  <view class="section">
    <view class="form-row">
      <view class="form-label">空间名称</view>
      <input class="form-input" type="text" maxlength="15" placeholder="{{name ? '' : '最多15字符'}}" value="{{name}}" bindinput="onInputName" />
    </view>
    <view class="form-row">
      <view class="form-label">墙体宽度</view>
      <input class="form-input" type="number" placeholder="44 ~ 1000 cm" value="{{wallW}}" bindinput="onInputW" />
      <view class="form-suffix">cm</view>
    </view>
    <view class="form-row">
      <view class="form-label">墙体高度</view>
      <input class="form-input" type="number" placeholder="232 ~ 1000 cm" value="{{wallH}}" bindinput="onInputH" />
      <view class="form-suffix">cm</view>
    </view>

    <view class="error" wx:if="{{errorMsg}}">{{errorMsg}}</view>
  </view>

  <view class="section">
    <view class="label">是否有转角衣柜</view>
    <option-scroll-card
      options="{{cornerOptions}}"
      selectedId="{{cornerType}}"
      variant="card"
      bind:change="onCornerChange" />
  </view>

  <view class="confirm-bar">
    <button class="confirm-btn" bindtap="onConfirm" disabled="{{!canSubmit}}">确认</button>
  </view>
</view>
