.page {
  min-height: 100vh;
  background: #f6f6f6;
  padding-bottom: 320rpx;
}

.section {
  background: #fff;
  margin: 16rpx 0;
  padding: 28rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 20rpx;
}

.wireframe .frame {
  background: #fafafa;
  border: 2rpx solid #e5e7eb;
  padding: 24rpx 16rpx;
}

/* 线框图：相对定位容器，编号绝对叠在 image 上 */
.wf-wrap {
  position: relative;
  width: 100%;
}

.wf-image {
  display: block;
  width: 100%;
  border-radius: 14rpx;
  background: #fff;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.wf-label {
  position: absolute;
  transform: translate(-50%, -50%);
  color: #EE822F;
  font-size: 36rpx;
  font-weight: 700;
  text-align: center;
  pointer-events: none;
}

.row-bottom, .row-top {
  display: flex;
  gap: 4rpx;
}

.row-top {
  margin-bottom: 6rpx;
}

.row-bottom {
  margin-top: 6rpx;
}

.cab {
  border: 2rpx solid #1f2937;
  height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fff;
}

.cab.raise {
  height: 80rpx;
  background: #fff7c2;
}

.cab .num {
  color: #EE822F;
  font-weight: 700;
  font-size: 32rpx;
}

.cab .code {
  font-size: 22rpx;
  color: #6b7280;
}

.cab-card {
  border: 2rpx solid #f3f4f6;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: #fafafa;
}

.cab-card-head {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
}

.cab-card-name {
  flex: 1;
  font-size: 30rpx;
  color: #1f2937;
  font-weight: 500;
}

.cab-card-price {
  font-size: 30rpx;
  color: #EE822F;
  font-weight: 600;
  margin-right: 16rpx;
}

.cab-card-detail {
  font-size: 24rpx;
  color: #2563eb;
}

.cab-card-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx 16rpx;
}

.cab-card-cell {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #6b7280;
}

.cab-card-cell .val {
  color: #1f2937;
  font-weight: 500;
}

.grand-total {
  margin-top: 16rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f3f4f6;
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  font-size: 28rpx;
  color: #1f2937;
}

.grand-total .big {
  font-size: 40rpx;
  color: #EE822F;
  font-weight: 700;
}

.grand-total-fixed {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 110rpx;
  background: linear-gradient(180deg, #fef9c3 0%, #fde68a 100%);
  padding: 22rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  font-size: 28rpx;
  color: #1f2937;
  z-index: 50;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}

.grand-total-fixed .big {
  font-size: 40rpx;
  color: #EE822F;
  font-weight: 700;
}

.sk-card {
  background: #fffbeb;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 24rpx 28rpx env(safe-area-inset-bottom);
  background: #fff;
  border-top: 2rpx solid #f3f4f6;
}

.btn {
  flex: 1;
  text-align: center;
  padding: 26rpx 0;
  border-radius: 999rpx;
  font-size: 30rpx;
}

.btn.primary {
  background: #1f2937;
  color: #fef9c3;
}

.btn.outline {
  border: 2rpx solid #d1d5db;
  color: #4b5563;
}

.modal {
  position: fixed;
  inset: 0;
  z-index: 200;
}

.mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.55);
}

.card {
  position: absolute;
  left: 5%;
  right: 5%;
  top: 8%;
  bottom: 8%;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  overflow-y: auto;
}

.card-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 34rpx;
  color: #1f2937;
  font-weight: 600;
}

.card-total {
  font-size: 32rpx;
  color: #EE822F;
  font-weight: 700;
}

.card-sec-title {
  font-size: 28rpx;
  color: #1f2937;
  margin: 16rpx 0 8rpx;
  font-weight: 500;
}

.tbl-row {
  display: grid;
  grid-template-columns: 1.4fr 1.4fr 1fr 1fr 1fr;
  gap: 8rpx;
  font-size: 22rpx;
  padding: 10rpx 4rpx;
  border-bottom: 1rpx solid #f3f4f6;
  color: #4b5563;
}

.tbl-row.tbl-head {
  font-weight: 600;
  color: #1f2937;
  background: #f9fafb;
}

.card-close {
  margin-top: 28rpx;
  text-align: center;
  background: #1f2937;
  color: #fef9c3;
  padding: 22rpx 0;
  border-radius: 999rpx;
}

.card.download {
  height: 600rpx;
  bottom: auto;
  top: 25%;
}

.dl-title {
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 12rpx;
}

.dl-tip {
  font-size: 24rpx;
  color: #6b7280;
  text-align: center;
  margin-bottom: 24rpx;
}

.dl-link {
  background: #f3f4f6;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 26rpx;
  color: #1f2937;
  margin-bottom: 28rpx;
  word-break: break-all;
}

.dl-actions {
  display: flex;
  gap: 16rpx;
}

.floating-toast {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.7);
  color: #fff;
  padding: 24rpx 40rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  z-index: 300;
}

.wf-bake-canvas {
  position: fixed;
  left: -9999px;
  top: 0;
  width: 1px;
  height: 1px;
  pointer-events: none;
  z-index: -1;
}
