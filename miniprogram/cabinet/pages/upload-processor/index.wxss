.up {
  min-height: 100vh;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.up-card {
  text-align: center;
  max-width: 620rpx;
  width: 100%;
}

.up-title {
  font-size: 32rpx;
  color: #4b5563;
  margin-bottom: 16rpx;
}

.up-sub {
  font-size: 26rpx;
  color: #9ca3af;
  margin-bottom: 24rpx;
  word-break: break-all;
}

.up-hint {
  font-size: 22rpx;
  color: #d1d5db;
}

/* 隐藏 webgl canvas —— 只是给 createScopedThreejs 挂 WebGL 上下文 */
.glb-parse-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 1px;
  height: 1px;
  pointer-events: none;
}
