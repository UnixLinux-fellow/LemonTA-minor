.page {
  min-height: 100vh;
  background: #fff;
  padding-bottom: 200rpx;
  display: flex;
  flex-direction: column;
}

.info-bar {
  background: #fef9c3;
  padding: 20rpx 28rpx;
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 16rpx;
}

.info-name {
  font-size: 32rpx;
  color: #1f2937;
  font-weight: 500;
}

.info-meta {
  font-size: 24rpx;
  color: #6b7280;
}

.canvas-zone {
  position: relative;
  background: linear-gradient(180deg, #fafaf9 60%, #f3f4f6);
  padding: 16rpx;
  display: flex;
  justify-content: center;
}

.webgl {
  width: 92vw;
  height: 420rpx;
  background: #fff;
  border: 4rpx solid #e5e7eb;
  border-radius: 6rpx;
}

/* 离屏 2d 截图画布：不可见、不占布局、不接收触摸，仅给截图 API 用 */
.snap2d {
  position: absolute;
  left: -9999px;
  top: 0;
  width: 1px;
  height: 1px;
  pointer-events: none;
}

.ctrl-bar {
  background: #fff;
  padding: 24rpx 28rpx;
  border-bottom: 2rpx solid #f3f4f6;
}

.ctrl-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.ctrl-btn {
  flex: 1;
  background: #f3f4f6;
  border-radius: 12rpx;
  padding: 18rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #4b5563;
}

.ctrl-btn.on {
  background: #14532d;
  color: #fef9c3;
}

.raise-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.raise-label {
  font-size: 26rpx;
  color: #4b5563;
}

/* 鞋柜模式: 加高开关整行置灰, switch disabled 属性已锁住交互 */
.raise-row-disabled {
  opacity: 0.4;
}

.raise-row-disabled .raise-label {
  color: #9ca3af;
}

.color-row {
  display: flex;
  gap: 24rpx;
  justify-content: space-between;
  align-items: center;
}

.color-row-label {
  flex: 0 0 auto;
  font-size: 24rpx;
  color: #374151;
  white-space: nowrap;
}

.color-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 0;
  border-radius: 24rpx;      /* iOS 感的大圆角, 跟 model-cell 28rpx 保持视觉同一语言 */
  border: 2rpx solid transparent;
}

.color-cell.active {
  border-color: #1f2937;
  background: #fef9c3;
}

.color-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(0, 0, 0, 0.1);
}

.color-name {
  font-size: 22rpx;
  color: #4b5563;
}

.picker-bar {
  background: #fff;
  padding: 16rpx 24rpx;
  flex: 1;
}

.picker-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
  align-items: center;
}

.picker-hint {
  flex: 1;
  font-size: 22rpx;
  color: #6b7280;
  text-align: right;
}

.tab {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  font-size: 26rpx;
  color: #4b5563;
}

.tab.active {
  background: #1f2937;
  color: #fef9c3;
}

.model-row {
  white-space: nowrap;
}

/* 自定义横向滑动条：scroll-view 原生 scrollbar 在小程序里展现不一致，
   也不能用 enhanced（会让 canvas 溢出）。这里跟随 bindscroll 自己渲一条进度条。*/
.scroll-indicator {
  position: relative;
  height: 16rpx;
  background: #e5e7eb;
  border-radius: 8rpx;
  margin: 14rpx 8rpx 0 8rpx;
}

.scroll-indicator-thumb {
  position: absolute;
  top: 0;
  bottom: 0;
  background: #1f2937;
  border-radius: 8rpx;
  pointer-events: none;
}

/* 默认可见 2 个 cell + 第 3 个露头一小段提示还有;
   picker-bar 内宽 ~702rpx, 2 cell + 1 gap = 2*310 + 14 = 634rpx, 剩 ~68rpx 露 3 张的头 (~22%)。
   每个 cell 内部一分为二: 左 70% 3D 缩略图, 右 30% 文字说明 (text_desc)。
   超过 2 个的模型通过父级 .model-row 的 scroll-x 横向滑动查看。 */
.model-cell {
  display: inline-flex;
  flex-direction: row;
  align-items: stretch;
  box-sizing: border-box;
  width: 310rpx;
  margin-right: 14rpx;
  border-radius: 28rpx;      /* iOS 感的大圆角 (参照 option-scroll-card 的 card 变体 32rpx, 这里 cell 稍小 → 28rpx) */
  border: 2rpx solid #e5e7eb;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.model-cell:last-child {
  margin-right: 0;
}

.model-cell.active {
  border-color: #1f2937;
  background: #fef9c3;
}

.model-thumb {
  width: 70%;
  height: 350rpx;
  flex-shrink: 0;
  overflow: hidden;
}

/* 右侧文字说明: 30% 宽度, 与 thumb 等高, 内容多时溢出隐藏 */
.model-desc {
  width: 30%;
  height: 350rpx;
  padding: 12rpx 10rpx;
  box-sizing: border-box;
  font-size: 20rpx;
  color: #4b5563;
  line-height: 1.4;
  white-space: normal;
  word-break: break-all;
  overflow: hidden;
  border-left: 2rpx solid #f3f4f6;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #fff;
  border-top: 2rpx solid #f3f4f6;
  padding: 20rpx 24rpx env(safe-area-inset-bottom);
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  padding: 26rpx 0;
  border-radius: 999rpx;
  background: #f3f4f6;
  text-align: center;
  font-size: 30rpx;
  color: #1f2937;
}

.action-btn.primary {
  background: #1f2937;
  color: #fef9c3;
}

.thumb-canvas {
  width: 100%;
  height: 100%;
  border-radius: 6rpx;
}
