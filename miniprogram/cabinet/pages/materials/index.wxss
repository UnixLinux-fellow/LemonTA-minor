.page {
  min-height: 100vh;
  position: relative;
  padding-bottom: 200rpx;
  overflow-x: hidden;
}

.preview-wireframe {
  position: relative;
  z-index: 1;
  background: linear-gradient(180deg, rgba(255, 247, 194, 0.85) 0%, rgba(253, 230, 138, 0.85) 100%);
  padding: 24rpx 28rpx 32rpx;
  margin: 16rpx 24rpx 0; /* 浮空卡片: 左右留白 */
  border-radius: 32rpx; /* iOS 感的大圆角 */
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.pw-title {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 14rpx;
}

.pw-image {
  display: block;
  width: 100%;
  border-radius: 14rpx;
  margin-bottom: 14rpx;
  background: #fff;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

/* 线框图：相对定位容器，让编号能绝对叠在图上 */
.pw-image-wrap {
  position: relative;
  width: 100%;
}

.pw-image-flush {
  margin-bottom: 0;
}

.wf-label {
  position: absolute;
  transform: translate(-50%, -50%);
  min-width: 40rpx;
  height: 40rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: rgba(238, 130, 47, 0.92);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 40rpx;
  text-align: center;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.25);
  pointer-events: none;
}

.pw-frame {
  background: #fff;
  border-radius: 14rpx;
  padding: 18rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.pw-row {
  display: flex;
  gap: 4rpx;
}

.pw-top {
  margin-bottom: 4rpx;
}

.pw-cab {
  border: 2rpx solid #1f2937;
  height: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 4rpx;
}

.pw-cab.raise {
  height: 60rpx;
  background: #fff7c2;
}

.pw-num {
  color: #EE822F;
  font-weight: 700;
  font-size: 26rpx;
}

.pw-code {
  font-size: 20rpx;
  color: #6b7280;
}

.space-info {
  position: relative;
  z-index: 1;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: saturate(180%) blur(30px);
  -webkit-backdrop-filter: saturate(180%) blur(30px);
  padding: 28rpx;
  margin: 16rpx 24rpx 0; /* 浮空卡片: 左右留白 */
  border-radius: 32rpx; /* iOS 感的大圆角 */
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.space-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1f2937;
}

.space-meta {
  font-size: 26rpx;
  color: #6b7280;
  margin-top: 8rpx;
}

.section {
  position: relative;
  z-index: 1;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: saturate(180%) blur(30px);
  -webkit-backdrop-filter: saturate(180%) blur(30px);
  margin: 16rpx 24rpx 0; /* 浮空卡片: 左右留白 + 卡片间距 */
  padding: 28rpx;
  border-radius: 32rpx; /* iOS 感的大圆角 */
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.sub {
  font-size: 26rpx;
  color: #9ca3af;
  margin: 6rpx 0 20rpx;
}

/* .opts / .opt* 网格样式已随所有 5 组选项迁移到 option-scroll-card 组件而废弃 */

/* 底栏样式与 cost 页 .bottom-bar 完全对齐: 全宽贴底、无浮空、border-top 分隔 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 24rpx 28rpx env(safe-area-inset-bottom);
  background: #fff;
  border-top: 2rpx solid #f3f4f6;
}

.btn {
  flex: 1;
  text-align: center;
  padding: 26rpx 0;
  border-radius: 999rpx;
  font-size: 30rpx;
}

.btn.primary {
  background: #1f2937;
  color: #fef9c3;
}

/* —— 费用预览 (吸顶) ——
   原始方案用 position:sticky, 但 .page 上有 overflow-x: hidden 会让 .page 本身
   成为 sticky 的 nearest scrolling ancestor, 而实际滚动容器是小程序 native page,
   sticky 永远拿不到滚动信号, 表现为完全不吸顶。改成 JS 驱动: onPageScroll 达阈值
   后加 .is-sticky 切到 position:fixed。占位块 .cost-preview-placeholder 保持
   文档流高度, 避免切换瞬间页面往上跳。 */
.cost-preview {
  position: relative;
  z-index: 10;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: saturate(180%) blur(30px);
  -webkit-backdrop-filter: saturate(180%) blur(30px);
  padding: 20rpx 28rpx;
  margin: 16rpx 24rpx 0; /* 浮空卡片: 左右留白 */
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  border-radius: 32rpx; /* iOS 感的大圆角 */
  overflow: hidden;
}

.cost-preview.is-sticky {
  position: fixed;
  top: 16rpx;
  left: 24rpx;
  right: 24rpx;
  margin: 0; /* fixed 定位时 margin 不再需要 */
}

/* 占位: is-sticky 时把 .cost-preview 抽离文档流, 用占位块占等高避免页面跳动 */
.cost-preview-placeholder {
  width: 100%;
}

.cp-grand {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid rgba(0,0,0,0.06);
}

.cp-grand-lbl {
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 600;
}

.cp-grand-val {
  font-size: 40rpx;
  color: #1f2937;
  font-weight: 700;
}

.cp-row {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
  gap: 24rpx;
}

.cp-item {
  flex: 1;
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.cp-item-lbl {
  font-size: 24rpx;
  color: #6b7280;
}

.cp-item-val {
  font-size: 26rpx;
  color: #1f2937;
  font-weight: 500;
}

.cp-notice {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #b45309;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.cp-retry {
  color: #EE822F;
  font-weight: 600;
}

/* —— 分类头部 flex —— */
.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.cat-cost {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 2rpx;
}

.cat-cost-fee {
  font-size: 22rpx;
  color: #1f2937;
  font-weight: 500;
}

.cat-cost-pct {
  font-size: 20rpx;
  color: #6b7280;
}
